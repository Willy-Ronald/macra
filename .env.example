# Macra — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ── Server-side only (Vercel env vars) ──────────────

# Anthropic Claude API (for AI meal generation)
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Stripe (secret keys — server-side only)
# Get these from: stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Supabase service role (server-side only)
# Get from: supabase.com → Project Settings → API
SUPABASE_SERVICE_ROLE_KEY=

# ── Client-side (VITE_ prefix = bundled into frontend) ──

# Supabase (for auth + database)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe (publishable key only — safe for client)
VITE_STRIPE_PUBLISHABLE_KEY=
